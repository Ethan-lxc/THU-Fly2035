  m_Name: OpeningInnerMonologue
  m_EditorClassIdentifier: 
  dialogueLines:
  - speaker: 1
    text: "\u7CDF\u7CD5\uFF01\u5B9E\u9A8C\u51FA\u95EE\u9898\u4E86\uFF0C\u6211\u7684\u610F\u8BC6\u4F3C\u4E4E\u6CA1\u80FD\u5B89\u5168\u4F20\u56DE\uFF01"
    overridePortrait: {fileID: 21300000, guid: 4f243e78b30c4af4fae18ee3859882d6, type: 3}
  - speaker: 1
    text: "(\u614C\u5F20\u7684\u56DB\u5904\u5F20\u671B\uFF0C\u53D1\u73B0\u81EA\u5DF1\u6B63\u5904\u4E8E\u4F4E\u7A7A\uFF0C\u56DB\u4E2A\u51E4\u7FFC\u8F6C\u52A8\u7740\u2026\u2026\uFF09"
    overridePortrait: {fileID: 21300000, guid: 4f243e78b30c4af4fae18ee3859882d6, type: 3}
  - speaker: 1
    text: "\u5927\u4E8B\u4E0D\u5999\uFF01\u6211\u7684\u610F\u8BC6\u88AB\u5C01\u95ED\u5728\u8FD9\u67B6\u81EA\u7531\u5DE1\u822A\u65E0\u4EBA\u673A\u4E2D\u4E86\uFF08\u60CA\u8BB6\u3001\u82E6\u95F7\uFF09"
    overridePortrait: {fileID: 21300000, guid: fa88e30afb6aeff4598a72f0816ce2eb, type: 3}
  - speaker: 1
    text: "\u4E8B\u5DF2\u81F3\u6B64\uFF0C\u53EA\u80FD\u6162\u6162\u60F3\u529E\u6CD5\uFF0C\u5012\u4E5F\u4E0D\u59A8\u8D81\u673A\u8131\u79BB\u9AD8\u538B\u7684\u7684\u5B66\u4E60\u751F\u6D3B\uFF0C\u5728\u6821\u56ED\u4E0A\u7A7A\u6F2B\u6E38\u4E00\u4E0B\u3002"
    overridePortrait: {fileID: 21300000, guid: 0f0a3bdac7d84d84dbad5c0674fadbdd, type: 3}
