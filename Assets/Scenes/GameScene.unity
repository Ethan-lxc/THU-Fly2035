  promptAfterNpcLine: "\u6309 \u7A7A\u683C \u7EE7\u7EED"
  lineNpcSaysOnQ: "\u201C\u5BF9\u4E0D\u8D77\uFF0C\u6211\u8FD8\u662F\u6CA1\u529E\u6CD5\uFF0C\u8FD9\u5B8C\u5168\u4E0D\u50CF\u662F\u6211\u5199\u7684\u3002"
  lineNpcSaysOnE: "\u53D1\u8FC7\u53BB\u4E86\uFF0C\u4E0D\u8FC7\u5979\u597D\u50CF\u4E00\u76F4\u6CA1\u56DE\u6211\uFF0C\u8FD8\u662F\u8C22\u8C22\u4F60\u9F13\u52B1\u6211\u53D1\u51FA\u6765\uFF0C\u8FC8\u51FA\u7B2C\u4E00\u6B65\u603B\u662F\u597D\u7684\u3002\u53EA\u662F\uFF0C\u5979\u4F1A\u56DE\u6211\u5417?"
  lineNpcSaysOnW: "\u4E5F\u8BB8\u5427\uFF0C\u770B\u6765\u4F60\u4E5F\u89C9\u5F97\u73B0\u5728\u4E0D\u662F\u6700\u597D\u7684\u65F6\u673A\uFF0C\u6211\u4F1A\u627E\u673A\u4F1A\u7684\u3002"
