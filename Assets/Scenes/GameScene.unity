  promptAcceptOrDecline: "\u6309 \u7A7A\u683C \u63A5\u53D7\u804A\u804A\uFF0C\u6309
    Esc \u62D2\u7EDD"
  promptBranchChoices: "\u6309 Q \u5E2E\u5199\uFF0C\u6309 E \u5EFA\u8BAE\u5148\u4E0D\u8868\u767D\uFF0C\u6309
    W \u9F13\u52B1\u76F4\u8BF4"
  lineDroneLeadInQ: "\u6211\u6765\u5E2E\u4F60\u5199\u5427"
  lineDroneLeadInW: "\u4F60\u53EF\u4EE5\u76F4\u63A5\u544A\u8BC9\u5979\uFF0C\u7528\u4F60\u81EA\u5DF1\u7684\u8BDD\u8BF4\u5C31\u597D"
