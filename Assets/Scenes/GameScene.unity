  waitingEventRewardCardSprite: {fileID: 21300000, guid: 1ea653493f79522449fa8e266b3e7d54, type: 3}
  waitingEventRewardCardTitle: 
  lineNpcAsksHelp: "\u6211\u6700\u8FD1\u603B\u662F\u5931\u7720\uFF0C\u7761\u4E0D\u597D\uFF0C\u4F60\u80FD\u7ED9\u6211\u4E00\u4E9B\u5EFA\u8BAE\u5417\uFF1F"
  lineNpcSaysWhenEscRejects: "\u679C\u7136\uFF0C\u4F60\u53EA\u662F\u4E2A\u65E0\u4EBA\u673A\uFF0C\u8FD8\u662F\u5E2E\u4E0D\u4E86\u6211\u3002"
  lineDroneAcceptsHelp: "\u6211\u60F3\u60F3\u600E\u4E48\u5E2E\u4F60\u3002"
  promptAcceptOrDecline: "\u6309 \u7A7A\u683C \u63A5\u53D7\u804A\u804A\uFF0C\u6309
    Esc \u62D2\u7EDD"
  promptBranchChoices: "\u6309 Q \u64CD\u573A\u6563\u5FC3\uFF0C\u6309 E \u68B3\u7406\u6C47\u62A5\uFF0C\u6309
    W \u53BB\u533B\u9662"
  lineDroneLeadInQ: "\u6211\u4EEC\u53BB\u64CD\u573A\u5427\u3002"
  lineDroneLeadInW: "\u8981\u4E0D\u8981\u53BB\u533B\u9662\u770B\u4E00\u4E0B\u5462\u5427"
  lineDroneLeadInE: "\u6211\u6765\u5E26\u4F60\u68B3\u7406\n\u4E0B\u660E\u5929\u7684\u6C47\u62A5\u5427\u3002"
  promptAfterLeadIn: "\u6309 \u7A7A\u683C \u7EE7\u7EED"
  promptAfterNpcLine: "\u6309 \u7A7A\u683C \u7EE7\u7EED"
  lineNpcSaysOnQ: "\u679C\u7136\u5728\u64CD\u573A\u4E0A\u5439\u98CE\u4F1A\u5FC3\u60C5\u53D8\u597D\uFF0C\u8C22\u8C22\u4F60\uFF0C\u6211\u5DF2\u7ECF\u4E0D\u62C5\u5FC3\u5566"
  lineNpcSaysOnE: "\u8C22\u8C22\u4F60\uFF01\u6211\u5BF9\u660E\u5929\u7684\u6C47\u62A5\u653E\u5FC3\u591A\u4E86\uFF0C\u53EA\u4E0D\u8FC7\u6211\u4EEC\u68B3\u7406\u5230\u73B0\u5728\u4E86\uFF0C\u8FD8\u6709\u7761\u89C9\u7684\u65F6\u95F4\u5417\uFF1F"
  lineNpcSaysOnW: "\u53BB\u533B\u9662\u5E72\u4EC0\u4E48\uFF0C\u73B0\u5728\u65F6\u95F4\u8FD9\u4E48\u7D27\uFF0C\u4F60\u8FD8\u662F\u522B\u7BA1\u6211\u4E86"
