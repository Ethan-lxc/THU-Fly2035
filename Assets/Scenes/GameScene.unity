  confessionAdviceRewardCardTitle: 
  lineNpcAsksHelp: "\u201C\u6211\u60F3\u660E\u5929\u548C\u5979\u8BF4\uFF0C\u4F46\u662F\u4E00\u76F4\u4E0D\u77E5\u9053\u600E\u4E48\u5F00\u53E3\u201D"
  lineNpcSaysWhenEscRejects: "\"\u8BF4\u5F97\u4E5F\u662F\uFF0C\u4F60\u53EA\u662F\u65E0\u4EBA\u673A\uFF0C\u53C8\u600E\u4E48\u4F1A\u7406\u89E3\u6211\u3002"
